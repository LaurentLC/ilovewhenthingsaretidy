{
  "manifest_version": 3,
  "name": "I love when things are tidy",
  "version": "1.0.0",
  "description": "Rewrites visible page text by sorting or shuffling letters inside words.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "I love when things are tidy",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "core/transform.js",
        "core/dom.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
